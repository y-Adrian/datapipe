# Clang-Format configuration for DataPipe
# Usage: clang-format -i -style=file src/*.c include/*.h

BasedOnStyle: LLVM
IndentWidth: 4
ColumnLimit: 100
UseTab: Never
BreakBeforeBraces: Linux
IndentCaseLabels: true
PointerAlignment: Left
SpaceAfterCStyleCast: false
SpaceBeforeParens: ControlStatements
